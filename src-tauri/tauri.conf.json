{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ckourse",
  "version": "1.0.1",
  "identifier": "com.ckourse.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 800,
        "maximized": true,
        "titleBarStyle": "Overlay",
        "acceptFirstMouse": true,
        "backgroundColor": "#0A0A0A"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffprobe",
      "binaries/ffmpeg"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null
    }
  }
}
